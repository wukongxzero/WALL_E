# Use a lightweight Ubuntu base image
FROM ubuntu:22.04

# Set up variables for Godot versions to easily update later
ENV GODOT_VERSION="3.5.3"
ENV GODOT_RELEASE="stable"

# Install required tools
RUN apt-get update && \
  apt-get install -y --no-install-recommends \
  ca-certificates \
  wget \
  unzip \
  && rm -rf /var/lib/apt/lists/*

# 1. Download and install the Godot Headless binary
RUN wget -q https://downloads.godotengine.org/${GODOT_VERSION}/Godot_v${GODOT_VERSION}-${GODOT_RELEASE}_linux_headless.64.zip && \
  unzip Godot_v${GODOT_VERSION}-${GODOT_RELEASE}_linux_headless.64.zip && \
  mv Godot_v${GODOT_VERSION}-${GODOT_RELEASE}_linux_headless.64 /usr/local/bin/godot && \
  rm Godot_v${GODOT_VERSION}-${GODOT_RELEASE}_linux_headless.64.zip

# 2. Download and install the Godot Export Templates
# Godot strictly expects these to be in ~/.local/share/godot/templates/<version>.<release>/
RUN wget -q https://downloads.godotengine.org/${GODOT_VERSION}/Godot_v${GODOT_VERSION}-${GODOT_RELEASE}_export_templates.tpz && \
  mkdir -p ~/.local/share/godot/templates/${GODOT_VERSION}.${GODOT_RELEASE} && \
  unzip Godot_v${GODOT_VERSION}-${GODOT_RELEASE}_export_templates.tpz && \
  mv templates/* ~/.local/share/godot/templates/${GODOT_VERSION}.${GODOT_RELEASE}/ && \
  rm -rf templates Godot_v${GODOT_VERSION}-${GODOT_RELEASE}_export_templates.tpz

# Set up the working directory where we will mount the project
WORKDIR /app

# The default command simply prints the Godot version to verify it works
ENTRYPOINT ["godot"]
CMD ["--version"]
